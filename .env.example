# Supabase (get these from your Supabase project settings → API)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Password protection (set this in Vercel dashboard, NOT here)
# Adding VITE_ to this would expose the password in the browser — don't do that.
# SITE_PASSWORD=your_shared_password_here
